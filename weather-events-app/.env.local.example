# Copy this file to .env.local and fill in your real API keys.
# Do NOT commit .env.local — it is gitignored.

# OpenWeatherMap current weather API key
# Get one at https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=

# Ticketmaster Discovery API key
# Get one at https://developer-acct.ticketmaster.com/user/login
TICKETMASTER_API_KEY=
